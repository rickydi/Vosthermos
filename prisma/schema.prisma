generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  nameEn   String?
  slug     String     @unique
  image    String?
  order    Int        @default(0)
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]  @relation("CategoryTree")
  products   Product[]
  promotions Promotion[]

  @@map("categories")
}

model Product {
  id                    Int            @id @default(autoincrement())
  sku                   String         @unique
  name                  String
  nameEn                String?
  description           String?
  descriptionEn         String?
  detailedDescription   String?        @db.Text
  detailedDescriptionEn String?        @db.Text
  price                 Decimal        @db.Decimal(10, 2)
  compareAtPrice      Decimal?       @db.Decimal(10, 2)
  slug                String         @unique
  availability        String         @default("InStock")
  categoryId          Int?
  category            Category?      @relation(fields: [categoryId], references: [id])
  images              ProductImage[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  workOrderItems      WorkOrderItem[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  position  Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id        Int      @id @default(autoincrement())
  stripeId  String   @unique
  email     String
  name      String
  phone     String?
  address   String?
  city      String?
  province  String?
  postalCode String?
  total     Decimal  @db.Decimal(10, 2)
  status    String   @default("pending")
  items     Json
  createdAt DateTime @default(now())

  @@map("orders")
}

model AdminUser {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String

  @@map("admin_users")
}

model AnalyticsSession {
  id         Int                @id @default(autoincrement())
  visitorId  String
  device     String?
  browser    String?
  referrer   String?
  city       String?
  region     String?
  country    String?
  startedAt  DateTime           @default(now())
  endedAt    DateTime?
  pageViews  AnalyticsPageView[]

  @@index([visitorId])
  @@index([startedAt])
  @@map("analytics_sessions")
}

model AnalyticsPageView {
  id        Int              @id @default(autoincrement())
  sessionId Int
  session   AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  page      String
  enteredAt DateTime         @default(now())
  duration  Int              @default(0)

  @@index([sessionId])
  @@index([enteredAt])
  @@map("analytics_page_views")
}

model AnalyticsDailyStat {
  id                 Int      @id @default(autoincrement())
  date               DateTime @unique @db.Date
  visitors           Int      @default(0)
  pageViews          Int      @default(0)
  avgSessionDuration Int      @default(0)

  @@map("analytics_daily_stats")
}

model AnalyticsFormEvent {
  id              Int      @id @default(autoincrement())
  sessionId       Int?
  visitorId       String?
  formType        String
  action          String
  fieldName       String?
  fieldsCompleted Json?
  fieldValues     Json?
  page            String?
  createdAt       DateTime @default(now())

  @@index([formType])
  @@index([createdAt])
  @@map("analytics_form_events")
}

model ChatConversation {
  id             String        @id @default(cuid())
  clientName     String
  clientPhone    String        @unique
  clientEmail    String?
  lastMessageAt  DateTime      @default(now())
  lastNotifiedAt DateTime?
  lastSeenAt     DateTime?
  isArchived     Boolean       @default(false)
  unreadCount    Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@map("chat_conversations")
}

model SiteSetting {
  key   String @id
  value String @db.Text

  @@map("site_settings")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     String
  senderName     String
  content        String           @db.Text
  imageUrl       String?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

model ChatNotifyMember {
  id              Int     @id @default(autoincrement())
  name            String
  phone           String
  isActive        Boolean @default(true)
  schedule        Json?

  @@map("chat_notify_members")
}

model BlogNotifyMember {
  id        Int     @id @default(autoincrement())
  name      String
  email     String
  isActive  Boolean @default(true)

  @@map("blog_notify_members")
}

model Promotion {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  type        String    @default("percent")
  value       Decimal   @db.Decimal(10, 2)
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  bgColor     String    @default("#e30718")
  createdAt   DateTime  @default(now())

  @@map("promotions")
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String    @db.Text
  coverImage  String?
  category    String    @default("conseils")
  tags        String[]  @default([])
  status      String    @default("draft")
  authorName  String    @default("Vosthermos")
  aiGenerated Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Appointment {
  id          Int        @id @default(autoincrement())
  name        String
  phone       String
  email       String?
  serviceType String
  date        DateTime   @db.Date
  timeSlot    String
  address     String?
  city        String?
  notes       String?    @db.Text
  status      String     @default("pending")
  createdAt   DateTime   @default(now())
  workOrder   WorkOrder?

  @@unique([date, timeSlot])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model SeoRanking {
  id        String   @id @default(cuid())
  city      String
  cityName  String
  keyword   String
  position  Int?
  aiMention Boolean  @default(false)
  url       String?
  checkedAt DateTime @default(now())

  @@index([city, checkedAt])
  @@map("seo_rankings")
}

// ─── Terrain: Bons de travail ────────────────────────────────────

model Technician {
  id         Int         @id @default(autoincrement())
  name       String
  email      String?     @unique
  phone      String?
  photoUrl   String?
  pin        String      // bcrypt hash du PIN 4 chiffres
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workOrders WorkOrder[]

  @@map("technicians")
}

model Client {
  id             Int          @id @default(autoincrement())
  name           String
  type           String       @default("particulier") // "particulier" | "gestionnaire"
  company        String?
  address        String?
  city           String?
  province       String       @default("QC")
  postalCode     String?
  phone          String?
  email          String?      @unique
  notes          String?      @db.Text
  passwordHash   String?
  portalToken    String?      @unique
  isPortalActive Boolean      @default(false)
  paymentTermsDays Int        @default(30)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  workOrders     WorkOrder[]
  units          ClientUnit[]
  buildings      Building[]
  managers       ManagerClient[]

  @@index([phone])
  @@index([type])
  @@map("clients")
}

model ClientUnit {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  buildingId  Int?
  building    Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  code        String
  description String?
  notes       String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  openings    UnitOpening[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
  @@index([buildingId])
  @@map("client_units")
}

model Building {
  id        Int          @id @default(autoincrement())
  clientId  Int
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  code      String       // "A", "B", "C", "D"
  name      String       // "Bâtiment A"
  address   String?
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  units     ClientUnit[]

  @@unique([clientId, code])
  @@index([clientId])
  @@map("buildings")
}

model UnitOpening {
  id          Int        @id @default(autoincrement())
  unitId      Int
  unit        ClientUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  type        String     // "fenetre" | "porte" | "porte-patio" | "porte-francaise"
  location    String     // "Salon · nord"
  description String?    @db.Text
  photoUrl    String?
  year        Int?
  brand       String?
  status      String     @default("ok") // "ok" | "active" | "done"
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([unitId])
  @@map("unit_openings")
}

model ManagerUser {
  id                      Int                @id @default(autoincrement())
  email                   String             @unique
  firstName               String
  lastName                String
  phone                   String?
  isActive                Boolean            @default(true)
  notifyNewInvoice        Boolean            @default(true)
  notifyWorkOrderScheduled Boolean           @default(true)
  notifyInvoiceOverdue    Boolean            @default(true)
  lastLoginAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  clients                 ManagerClient[]
  sessions                ManagerSession[]
  magicTokens             ManagerMagicToken[]

  @@index([email])
  @@map("manager_users")
}

model ManagerClient {
  managerId   Int
  manager     ManagerUser @relation(fields: [managerId], references: [id], onDelete: Cascade)
  clientId    Int
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  permissions String[]    @default(["view_work_orders","view_invoices","view_quotes","request_intervention","approve_quotes","manage_units","manage_openings"])
  createdAt   DateTime    @default(now())

  @@id([managerId, clientId])
  @@index([clientId])
  @@map("manager_clients")
}

model ManagerSession {
  token     String      @id
  managerId Int
  manager   ManagerUser @relation(fields: [managerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime    @default(now())

  @@index([managerId])
  @@index([expiresAt])
  @@map("manager_sessions")
}

model ManagerMagicToken {
  token     String      @id
  managerId Int
  manager   ManagerUser @relation(fields: [managerId], references: [id], onDelete: Cascade)
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([managerId])
  @@index([expiresAt])
  @@map("manager_magic_tokens")
}

model WorkOrder {
  id                     Int             @id @default(autoincrement())
  number                 String          @unique
  clientId               Int
  client                 Client          @relation(fields: [clientId], references: [id])
  technicianId           Int?
  technician             Technician?     @relation(fields: [technicianId], references: [id])
  appointmentId          Int?            @unique
  appointment            Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  date                   DateTime        @db.Date
  arrivalAt              DateTime?
  departureAt            DateTime?
  durationMinutes        Int?
  interventionAddress    String?
  interventionCity       String?
  interventionPostalCode String?
  description            String?         @db.Text
  photos                 String[]        @default([])
  signatureUrl           String?
  statut                 String          @default("draft")
  notes                  String?         @db.Text
  visibleAuClient        Boolean         @default(true)
  totalPieces            Decimal         @default(0) @db.Decimal(10, 2)
  totalLabor             Decimal         @default(0) @db.Decimal(10, 2)
  subtotal               Decimal         @default(0) @db.Decimal(10, 2)
  tps                    Decimal         @default(0) @db.Decimal(10, 2)
  tvq                    Decimal         @default(0) @db.Decimal(10, 2)
  total                  Decimal         @default(0) @db.Decimal(10, 2)
  viewedByManagerAt      DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  items                  WorkOrderItem[]
  sections               WorkOrderSection[]

  @@index([clientId])
  @@index([technicianId])
  @@index([statut])
  @@index([date])
  @@map("work_orders")
}

model Counter {
  key   String @id
  value Int    @default(0)

  @@map("counters")
}

model WorkOrderSection {
  id          Int             @id @default(autoincrement())
  workOrderId Int
  workOrder   WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  unitCode    String
  notes       String?         @db.Text
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  items       WorkOrderItem[]

  @@index([workOrderId])
  @@map("work_order_sections")
}

model WorkOrderItem {
  id          Int               @id @default(autoincrement())
  workOrderId Int
  workOrder   WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  sectionId   Int?
  section     WorkOrderSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  productId   Int?
  product     Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  serviceId   Int?
  service     Service?          @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description String
  quantity    Decimal           @db.Decimal(10, 3)
  unitPrice   Decimal           @db.Decimal(10, 2)
  totalPrice  Decimal           @db.Decimal(10, 2)
  itemType    String            @default("piece")
  position    Int               @default(0)

  @@index([workOrderId])
  @@index([sectionId])
  @@map("work_order_items")
}

model Service {
  id             Int             @id @default(autoincrement())
  code           String          @unique
  name           String
  category       String          // thermo | installation | ajustement | quincaillerie | vitre | autre
  price          Decimal         @db.Decimal(10, 2)
  description    String?         @db.Text
  isActive       Boolean         @default(true)
  isPreset       Boolean         @default(false)
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workOrderItems WorkOrderItem[]

  @@index([category])
  @@index([isActive])
  @@map("services")
}
